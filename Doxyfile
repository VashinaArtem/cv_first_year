OUTPUT_DIRECTORY = docs
PROJECT_NAME       = "Polevoy_sem1"
PROJECT_BRIEF      = "Документация проекта"
OUTPUT_LANGUAGE    = Russian
INPUT_ENCODING     = UTF-8
EXTRACT_ALL        = YES
FULL_PATH_NAMES    = NO
STRIP_FROM_PATH    = C:/dev/Polevoy_sem1
LATEX_SOURCE_CODE  = YES
PAPER_TYPE         = a4


GENERATE_HTML    = NO
